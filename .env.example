# Supabase Authentication & Database
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Logicc AI Integration (primary; OpenAI-compatible API)
LOGICC_API_KEY=
LOGICC_ENDPOINT_URL=https://api.logicc.io/v1
LOGICC_MODEL=gpt-5-nano

# Langdock AI Integration (explicit fallback only)
LANGDOCK_API_KEY=
LANGDOCK_ENDPOINT_URL=
LANGDOCK_MODEL=

# Deprecated compatibility aliases; do not use in new deployments.
LANGDOCK_API_CODE=
MODEL=

# IONOS AI Assistant API
IONOS_API_KEY=

# HubSpot CRM API
HUBSPOT_API_KEY=

# WhatsApp Cloud API webhook (Phase 3A foundation -- no live sending yet)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Explicit AI text-completion provider selection (ADR-011). Selection is
# NEVER inferred from which credentials happen to be present -- both of
# these must be set for their named provider to be reachable at all.
AI_TEXT_PRIMARY_PROVIDER=logicc
AI_TEXT_FALLBACK_PROVIDER=langdock
